<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landlord Registration - Fleming Lettings</title>

    <style>
        @font-face {
            font-family: 'Switzer';
            font-weight: 400;
            src: url('https://fleminglettings.co.uk/wp-content/uploads/2023/10/Switzer-Regular.otf') format('OpenType');
        }
        @font-face {
            font-family: 'Switzer';
            font-weight: 700;
            src: url('https://fleminglettings.co.uk/wp-content/uploads/2023/10/Switzer-Bold.otf') format('OpenType');
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #25073B 0%, #DC006D 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 900px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
            position: relative;
        }

        /* Header */
        .header {
            background: white;
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #f0f0f0;
        }

        .logo {
            height: 50px;
            object-fit: contain;
        }

        .back-button {
            background: transparent;
            border: 1px solid #DC006D;
            color: #DC006D;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            font-weight: 500;
        }

        .back-button:hover {
            background: #DC006D;
            color: white;
        }

        /* Progress Bar */
        .progress-container {
            background: #f0f0f0;
            height: 4px;
        }

        .progress-bar {
            background: linear-gradient(90deg, #DC006D 0%, #25073B 100%);
            height: 100%;
            width: 0%;
            transition: width 0.4s ease;
        }

        /* Form Container */
        .form-wrapper {
            padding: 60px 40px;
            min-height: 500px;
        }

        /* Steps */
        .step {
            display: none;
            animation: fadeIn 0.4s ease-in;
        }

        .step.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Form Elements */
        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            color: #25073B;
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 15px;
        }

        .form-group label .required {
            color: #DC006D;
        }

        .form-group input[type="text"],
        .form-group input[type="email"],
        .form-group input[type="tel"],
        .form-group input[type="date"],
        .form-group input[type="number"],
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #e5e5e5;
            border-radius: 10px;
            font-size: 15px;
            font-family: 'Switzer', sans-serif;
            transition: all 0.3s;
            background: white;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #DC006D;
            box-shadow: 0 0 0 3px rgba(220, 0, 109, 0.1);
        }

        .form-group textarea {
            min-height: 100px;
            resize: vertical;
        }

        /* Radio Buttons */
        .radio-group {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .radio-option {
            display: flex;
            align-items: center;
            cursor: pointer;
        }

        .radio-option input[type="radio"] {
            width: 20px;
            height: 20px;
            margin-right: 8px;
            cursor: pointer;
            accent-color: #DC006D;
        }

        .radio-option label {
            margin: 0;
            cursor: pointer;
            font-weight: 500;
            color: #333;
        }

        /* Checkbox */
        .checkbox-group {
            display: flex;
            align-items: flex-start;
            margin: 20px 0;
        }

        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-right: 12px;
            margin-top: 2px;
            cursor: pointer;
            accent-color: #DC006D;
            flex-shrink: 0;
        }

        .checkbox-group label {
            margin: 0;
            font-size: 14px;
            color: #555;
            font-weight: 400;
            line-height: 1.6;
            cursor: pointer;
        }

        .checkbox-group label a {
            color: #DC006D;
            text-decoration: underline;
        }

        /* Grid Layout */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }

        /* Buttons */
        .button-group {
            display: flex;
            justify-content: space-between;
            margin-top: 40px;
            gap: 15px;
        }

        .btn {
            padding: 14px 32px;
            border: none;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Switzer', sans-serif;
        }

        .btn-primary {
            background: linear-gradient(135deg, #DC006D 0%, #25073B 100%);
            color: white;
            flex: 1;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(220, 0, 109, 0.3);
        }

        .btn-secondary {
            background: white;
            color: #DC006D;
            border: 2px solid #DC006D;
            flex: 0 0 auto;
        }

        .btn-secondary:hover {
            background: #DC006D;
            color: white;
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Step Indicator */
        .step-indicator {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 40px;
            gap: 15px;
        }

        .step-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #e5e5e5;
            transition: all 0.3s;
        }

        .step-dot.active {
            background: #DC006D;
            width: 40px;
            border-radius: 6px;
        }

        /* Headings */
        h2 {
            color: #25073B;
            font-size: 28px;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .step-subtitle {
            color: #666;
            font-size: 16px;
            margin-bottom: 30px;
        }

        /* Success/Error Messages */
        .message {
            padding: 16px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: none;
        }

        .message.show {
            display: block;
        }

        .message.success {
            background: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
        }

        .message.error {
            background: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }

        /* Loading Spinner */
        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #DC006D;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
            display: inline-block;
            margin-left: 10px;
            vertical-align: middle;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Joint Application Section */
        .joint-section {
            background: #f9f9f9;
            padding: 30px;
            border-radius: 15px;
            margin-top: 30px;
            border: 2px dashed #DC006D;
        }

        .joint-section h3 {
            color: #25073B;
            font-size: 22px;
            margin-bottom: 20px;
        }

        /* Property Section */
        .property-section {
            background: #f5f5f5;
            padding: 25px;
            border-radius: 12px;
            margin-top: 25px;
        }

        .property-section h3 {
            color: #25073B;
            font-size: 20px;
            margin-bottom: 15px;
            font-weight: 600;
        }

        /* Add Property Button */
        .add-property-btn {
            background: #f0f0f0;
            border: 2px dashed #DC006D;
            color: #DC006D;
            padding: 12px 24px;
            border-radius: 20px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 15px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .add-property-btn:hover {
            background: #DC006D;
            color: white;
        }

        /* Responsive */
        @media (max-width: 640px) {
            .container {
                border-radius: 0;
            }

            .form-wrapper {
                padding: 40px 25px;
            }

            .header {
                padding: 15px 20px;
            }

            .logo {
                height: 40px;
            }

            h2 {
                font-size: 24px;
            }

            .button-group {
                flex-direction: column-reverse;
            }

            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <img src="Logo for form.png" alt="Fleming Lettings" class="logo">
            <a href="https://fleminglettings.co.uk" class="back-button">← Back to Site</a>
        </div>

        <!-- Progress Bar -->
        <div class="progress-container">
            <div class="progress-bar" id="progressBar"></div>
        </div>

        <!-- Form Wrapper -->
        <div class="form-wrapper">
            <form id="landlordForm">
                <!-- Step 1: Registration Type & Personal Details -->
                <div class="step active" data-step="1">
                    <div class="step-indicator">
                        <div class="step-dot active"></div>
                        <div class="step-dot"></div>
                        <div class="step-dot"></div>
                        <div class="step-dot"></div>
                    </div>

                    <h2>Landlord Registration</h2>
                    <p class="step-subtitle">Let's start with your personal details</p>

                    <div class="form-group">
                        <label>Is this a sole or joint registration? <span class="required">*</span></label>
                        <div class="radio-group">
                            <div class="radio-option">
                                <input type="radio" id="sole" name="registration_type" value="Sole" checked>
                                <label for="sole">Sole</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" id="joint" name="registration_type" value="Joint">
                                <label for="joint">Joint</label>
                            </div>
                        </div>
                    </div>

                    <h3 style="margin-top: 30px; margin-bottom: 20px; color: #25073B;">Primary Applicant Details</h3>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="firstName">First Name <span class="required">*</span></label>
                            <input type="text" id="firstName" name="firstName" required>
                        </div>
                        <div class="form-group">
                            <label for="surname">Surname <span class="required">*</span></label>
                            <input type="text" id="surname" name="surname" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="address">Home Address <span class="required">*</span></label>
                        <input type="text" id="address" name="address" required>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="postcode">Postcode <span class="required">*</span></label>
                            <input type="text" id="postcode" name="postcode" required>
                        </div>
                        <div class="form-group">
                            <label for="yearsAtAddress">Years at Address <span class="required">*</span></label>
                            <input type="number" id="yearsAtAddress" name="yearsAtAddress" min="0" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="dob">Date of Birth <span class="required">*</span></label>
                            <input type="date" id="dob" name="dob" required>
                        </div>
                        <div class="form-group">
                            <label for="nationality">Nationality <span class="required">*</span></label>
                            <select id="nationality" name="nationality" required>
                                <option value="">Please select an option</option>
                                <option value="English, Welsh, Scottish, Northern Irish or British">English, Welsh, Scottish, Northern Irish or British</option>
                                <option value="Irish">Irish</option>
                                <option value="Indian">Indian</option>
                                <option value="Pakistani">Pakistani</option>
                                <option value="Bangladeshi">Bangladeshi</option>
                                <option value="Chinese">Chinese</option>
                                <option value="African">African</option>
                                <option value="Caribbean">Caribbean</option>
                                <option value="Arab">Arab</option>
                                <option value="White and Black Caribbean">White and Black Caribbean</option>
                                <option value="White and Black African">White and Black African</option>
                                <option value="White and Asian">White and Asian</option>
                                <option value="Any other Mixed or multiple ethnic background">Any other Mixed or multiple ethnic background</option>
                                <option value="Any other Asian background">Any other Asian background</option>
                                <option value="Any other White background">Any other White background</option>
                                <option value="Any other Black, Black British, or Caribbean background">Any other Black, Black British, or Caribbean background</option>
                                <option value="Any other ethnic group">Any other ethnic group</option>
                                <option value="Rather not say">Rather not say</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="email">Email Address <span class="required">*</span></label>
                            <input type="email" id="email" name="email" required>
                        </div>
                        <div class="form-group">
                            <label for="phone">Contact Number <span class="required">*</span></label>
                            <input type="tel" id="phone" name="phone" required>
                        </div>
                    </div>

                    <!-- Joint Applicant (conditionally shown) -->
                    <div id="jointSection" class="joint-section" style="display: none;">
                        <h3>Joint Applicant Details</h3>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="firstName2">First Name <span class="required">*</span></label>
                                <input type="text" id="firstName2" name="firstName2">
                            </div>
                            <div class="form-group">
                                <label for="surname2">Surname <span class="required">*</span></label>
                                <input type="text" id="surname2" name="surname2">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="address2">Home Address <span class="required">*</span></label>
                            <input type="text" id="address2" name="address2">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="postcode2">Postcode <span class="required">*</span></label>
                                <input type="text" id="postcode2" name="postcode2">
                            </div>
                            <div class="form-group">
                                <label for="yearsAtAddress2">Years at Address <span class="required">*</span></label>
                                <input type="number" id="yearsAtAddress2" name="yearsAtAddress2" min="0">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="dob2">Date of Birth <span class="required">*</span></label>
                                <input type="date" id="dob2" name="dob2">
                            </div>
                            <div class="form-group">
                                <label for="nationality2">Nationality <span class="required">*</span></label>
                                <select id="nationality2" name="nationality2">
                                    <option value="">Please select an option</option>
                                    <option value="English, Welsh, Scottish, Northern Irish or British">English, Welsh, Scottish, Northern Irish or British</option>
                                    <option value="Irish">Irish</option>
                                    <option value="Indian">Indian</option>
                                    <option value="Pakistani">Pakistani</option>
                                    <option value="Bangladeshi">Bangladeshi</option>
                                    <option value="Chinese">Chinese</option>
                                    <option value="African">African</option>
                                    <option value="Caribbean">Caribbean</option>
                                    <option value="Arab">Arab</option>
                                    <option value="White and Black Caribbean">White and Black Caribbean</option>
                                    <option value="White and Black African">White and Black African</option>
                                    <option value="White and Asian">White and Asian</option>
                                    <option value="Any other Mixed or multiple ethnic background">Any other Mixed or multiple ethnic background</option>
                                    <option value="Any other Asian background">Any other Asian background</option>
                                    <option value="Any other White background">Any other White background</option>
                                    <option value="Any other Black, Black British, or Caribbean background">Any other Black, Black British, or Caribbean background</option>
                                    <option value="Any other ethnic group">Any other ethnic group</option>
                                    <option value="Rather not say">Rather not say</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="email2">Email Address <span class="required">*</span></label>
                                <input type="email" id="email2" name="email2">
                            </div>
                            <div class="form-group">
                                <label for="phone2">Contact Number <span class="required">*</span></label>
                                <input type="tel" id="phone2" name="phone2">
                            </div>
                        </div>
                    </div>

                    <div class="button-group">
                        <button type="button" class="btn btn-primary" onclick="nextStep()">Next Step →</button>
                    </div>
                </div>

                <!-- Step 2: Property Details -->
                <div class="step" data-step="2">
                    <div class="step-indicator">
                        <div class="step-dot"></div>
                        <div class="step-dot active"></div>
                        <div class="step-dot"></div>
                        <div class="step-dot"></div>
                    </div>

                    <h2>Property Details</h2>
                    <p class="step-subtitle">Tell us about your rental property</p>

                    <div id="propertiesContainer">
                        <!-- Property 1 -->
                        <div class="property-section" data-property="1">
                            <h3>Property 1</h3>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="propertyAddress">Rental Property Address <span class="required">*</span></label>
                                    <input type="text" id="propertyAddress" name="propertyAddress" required>
                                </div>
                                <div class="form-group">
                                    <label for="propertyPostcode">Property Postcode <span class="required">*</span></label>
                                    <input type="text" id="propertyPostcode" name="propertyPostcode" required>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="bedrooms">Number of Bedrooms <span class="required">*</span></label>
                                    <select id="bedrooms" name="bedrooms" required>
                                        <option value="">Please select</option>
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                        <option value="5">5</option>
                                        <option value="6+">6+</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Is there offroad parking?</label>
                                    <div class="radio-group">
                                        <div class="radio-option">
                                            <input type="radio" id="parkingYes" name="offroadParking" value="Yes" checked>
                                            <label for="parkingYes">Yes</label>
                                        </div>
                                        <div class="radio-option">
                                            <input type="radio" id="parkingNo" name="offroadParking" value="No">
                                            <label for="parkingNo">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label>Is this property already let? <span class="required">*</span></label>
                                    <div class="radio-group">
                                        <div class="radio-option">
                                            <input type="radio" id="alreadyLetYes" name="alreadyLet" value="Yes" onchange="toggleAlreadyLetSection()">
                                            <label for="alreadyLetYes">Yes</label>
                                        </div>
                                        <div class="radio-option">
                                            <input type="radio" id="alreadyLetNo" name="alreadyLet" value="No" checked onchange="toggleAlreadyLetSection()">
                                            <label for="alreadyLetNo">No</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Is there a mortgage attached? <span class="required">*</span></label>
                                    <div class="radio-group">
                                        <div class="radio-option">
                                            <input type="radio" id="mortgageYes" name="mortgageAttached" value="Yes">
                                            <label for="mortgageYes">Yes</label>
                                        </div>
                                        <div class="radio-option">
                                            <input type="radio" id="mortgageNo" name="mortgageAttached" value="No" checked>
                                            <label for="mortgageNo">No</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Already Let Section -->
                            <div id="alreadyLetSection" style="display: none; margin-top: 20px; padding: 20px; background: white; border-radius: 10px;">
                                <h4 style="color: #25073B; margin-bottom: 15px;">Current Tenancy Details</h4>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="tenancyType">Type of Tenancy <span class="required">*</span></label>
                                        <select id="tenancyType" name="tenancyType">
                                            <option value="">Please select</option>
                                            <option value="Ad-hoc">Ad-hoc</option>
                                            <option value="Contractual">Contractual</option>
                                            <option value="Fixed Term">Fixed Term</option>
                                            <option value="Monthly Rolling">Monthly Rolling</option>
                                            <option value="No Contract">No Contract</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="currentManagement">Current Management <span class="required">*</span></label>
                                        <select id="currentManagement" name="currentManagement">
                                            <option value="">Please select</option>
                                            <option value="Independently">Independently</option>
                                            <option value="Estate Agent">Estate Agent</option>
                                            <option value="Letting Agency">Letting Agency</option>
                                            <option value="Housing Association">Housing Association</option>
                                            <option value="Unsure">Unsure</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="lengthOfLet">Length of Current Let (months) <span class="required">*</span></label>
                                        <input type="number" id="lengthOfLet" name="lengthOfLet" min="0">
                                    </div>
                                    <div class="form-group">
                                        <label for="monthlyRentalIncome">Monthly Rental Income (£) <span class="required">*</span></label>
                                        <input type="number" id="monthlyRentalIncome" name="monthlyRentalIncome" min="0" step="0.01">
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label>Are you considering increasing the rent?</label>
                                    <div class="radio-group">
                                        <div class="radio-option">
                                            <input type="radio" id="rentIncreaseYes" name="consideringRentIncrease" value="Yes" onchange="toggleRentIncreaseField()">
                                            <label for="rentIncreaseYes">Yes</label>
                                        </div>
                                        <div class="radio-option">
                                            <input type="radio" id="rentIncreaseNo" name="consideringRentIncrease" value="No" checked onchange="toggleRentIncreaseField()">
                                            <label for="rentIncreaseNo">No</label>
                                        </div>
                                    </div>
                                </div>

                                <div id="rentIncreaseField" style="display: none;">
                                    <div class="form-group">
                                        <label for="newRentAmount">New Rent Amount (£)</label>
                                        <input type="number" id="newRentAmount" name="newRentAmount" min="0" step="0.01">
                                    </div>
                                </div>
                            </div>

                            <div class="form-row" style="margin-top: 20px;">
                                <div class="form-group">
                                    <label for="ownershipStructure">Ownership Structure <span class="required">*</span></label>
                                    <select id="ownershipStructure" name="ownershipStructure" required>
                                        <option value="">Please select</option>
                                        <option value="Owned outright">Owned outright</option>
                                        <option value="Mortgaged">Mortgaged</option>
                                        <option value="Commercial investment">Commercial investment</option>
                                        <option value="Sub-let">Sub-let</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="propertyCondition">Property Condition <span class="required">*</span></label>
                                    <select id="propertyCondition" name="propertyCondition" required>
                                        <option value="">Please select</option>
                                        <option value="Newly refurbished">Newly refurbished</option>
                                        <option value="Very good">Very good</option>
                                        <option value="Good">Good</option>
                                        <option value="Average">Average</option>
                                        <option value="Poor">Poor</option>
                                        <option value="Needs improvement">Needs improvement</option>
                                        <option value="Unsure">Unsure</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Are you looking to source a new tenant?</label>
                                <div class="radio-group">
                                    <div class="radio-option">
                                        <input type="radio" id="newTenantYes" name="lookingForNewTenant" value="Yes" onchange="toggleNewTenantReason()">
                                        <label for="newTenantYes">Yes</label>
                                    </div>
                                    <div class="radio-option">
                                        <input type="radio" id="newTenantNo" name="lookingForNewTenant" value="No" checked onchange="toggleNewTenantReason()">
                                        <label for="newTenantNo">No</label>
                                    </div>
                                </div>
                            </div>

                            <div id="newTenantReasonField" style="display: none;">
                                <div class="form-group">
                                    <label for="newTenantReason">Reason for sourcing a new tenant <span class="required">*</span></label>
                                    <textarea id="newTenantReason" name="newTenantReason" rows="3"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="button-group">
                        <button type="button" class="btn btn-secondary" onclick="prevStep()">← Back</button>
                        <button type="button" class="btn btn-primary" onclick="nextStep()">Next Step →</button>
                    </div>
                </div>

                <!-- Step 3: Compliance -->
                <div class="step" data-step="3">
                    <div class="step-indicator">
                        <div class="step-dot"></div>
                        <div class="step-dot"></div>
                        <div class="step-dot active"></div>
                        <div class="step-dot"></div>
                    </div>

                    <h2>Compliance Certificates</h2>
                    <p class="step-subtitle">Please provide information about compliance certificates</p>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Valid EPC Certificate? <span class="required">*</span></label>
                            <div class="radio-group">
                                <div class="radio-option">
                                    <input type="radio" id="epcYes" name="epcCertificate" value="Yes">
                                    <label for="epcYes">Yes</label>
                                </div>
                                <div class="radio-option">
                                    <input type="radio" id="epcNo" name="epcCertificate" value="No">
                                    <label for="epcNo">No</label>
                                </div>
                                <div class="radio-option">
                                    <input type="radio" id="epcUnsure" name="epcCertificate" value="Unsure" checked>
                                    <label for="epcUnsure">Unsure</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Valid EICR Certificate? <span class="required">*</span></label>
                            <div class="radio-group">
                                <div class="radio-option">
                                    <input type="radio" id="eicrYes" name="eicrCertificate" value="Yes">
                                    <label for="eicrYes">Yes</label>
                                </div>
                                <div class="radio-option">
                                    <input type="radio" id="eicrNo" name="eicrCertificate" value="No">
                                    <label for="eicrNo">No</label>
                                </div>
                                <div class="radio-option">
                                    <input type="radio" id="eicrUnsure" name="eicrCertificate" value="Unsure" checked>
                                    <label for="eicrUnsure">Unsure</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Valid Gas Safety Certificate? <span class="required">*</span></label>
                        <div class="radio-group">
                            <div class="radio-option">
                                <input type="radio" id="gasYes" name="gasCertificate" value="Yes">
                                <label for="gasYes">Yes</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" id="gasNo" name="gasCertificate" value="No">
                                <label for="gasNo">No</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" id="gasUnsure" name="gasCertificate" value="Unsure" checked>
                                <label for="gasUnsure">Unsure</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" id="gasNA" name="gasCertificate" value="N/A (No Gas)">
                                <label for="gasNA">N/A (No Gas)</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="additionalNotes">Additional Notes or Questions</label>
                        <textarea id="additionalNotes" name="additionalNotes" rows="4" placeholder="Please share any additional information or questions you may have..."></textarea>
                    </div>

                    <div class="button-group">
                        <button type="button" class="btn btn-secondary" onclick="prevStep()">← Back</button>
                        <button type="button" class="btn btn-primary" onclick="nextStep()">Next Step →</button>
                    </div>
                </div>

                <!-- Step 4: Review & Submit -->
                <div class="step" data-step="4">
                    <div class="step-indicator">
                        <div class="step-dot"></div>
                        <div class="step-dot"></div>
                        <div class="step-dot"></div>
                        <div class="step-dot active"></div>
                    </div>

                    <h2>Review & Submit</h2>
                    <p class="step-subtitle">Please review your information and accept our terms</p>

                    <div id="reviewContent" style="background: #f9f9f9; padding: 25px; border-radius: 12px; margin-bottom: 25px;">
                        <!-- Review content will be populated by JavaScript -->
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="termsConsent" name="termsConsent" required>
                        <label for="termsConsent">
                            I confirm that the information provided is accurate and I have read and agree to
                            <a href="https://fleminglettings.co.uk/terms-and-conditions/" target="_blank">Fleming Lettings Terms & Conditions</a>
                            and
                            <a href="https://fleminglettings.co.uk/privacy-policy/" target="_blank">Privacy Policy</a>. <span class="required">*</span>
                        </label>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="marketingConsent" name="marketingConsent">
                        <label for="marketingConsent">
                            I would like to receive updates, property news, and special offers from Fleming Lettings via email and SMS.
                        </label>
                    </div>

                    <div id="messageContainer"></div>

                    <div class="button-group">
                        <button type="button" class="btn btn-secondary" onclick="prevStep()">← Back</button>
                        <button type="submit" class="btn btn-primary" id="submitBtn">Submit Application</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script>
        let currentStep = 1;
        const totalSteps = 4;

        // Toggle joint applicant section
        document.querySelectorAll('input[name="registration_type"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const jointSection = document.getElementById('jointSection');
                if (this.value === 'Joint') {
                    jointSection.style.display = 'block';
                    // Make joint fields required
                    document.querySelectorAll('#jointSection input[required], #jointSection select[required]').forEach(input => {
                        input.removeAttribute('disabled');
                    });
                } else {
                    jointSection.style.display = 'none';
                    // Make joint fields not required
                    document.querySelectorAll('#jointSection input, #jointSection select').forEach(input => {
                        input.setAttribute('disabled', 'disabled');
                    });
                }
            });
        });

        function toggleAlreadyLetSection() {
            const alreadyLet = document.querySelector('input[name="alreadyLet"]:checked').value;
            const section = document.getElementById('alreadyLetSection');
            if (alreadyLet === 'Yes') {
                section.style.display = 'block';
            } else {
                section.style.display = 'none';
            }
        }

        function toggleRentIncreaseField() {
            const consideringIncrease = document.querySelector('input[name="consideringRentIncrease"]:checked')?.value;
            const field = document.getElementById('rentIncreaseField');
            if (consideringIncrease === 'Yes') {
                field.style.display = 'block';
            } else {
                field.style.display = 'none';
            }
        }

        function toggleNewTenantReason() {
            const lookingForNew = document.querySelector('input[name="lookingForNewTenant"]:checked').value;
            const field = document.getElementById('newTenantReasonField');
            if (lookingForNew === 'Yes') {
                field.style.display = 'block';
            } else {
                field.style.display = 'none';
            }
        }

        function updateProgressBar() {
            const progress = (currentStep / totalSteps) * 100;
            document.getElementById('progressBar').style.width = progress + '%';
        }

        function nextStep() {
            // Validate current step before proceeding
            const currentStepEl = document.querySelector(`.step[data-step="${currentStep}"]`);
            const inputs = currentStepEl.querySelectorAll('input[required]:not([disabled]), select[required]:not([disabled]), textarea[required]');

            let valid = true;
            inputs.forEach(input => {
                if (!input.value || (input.type === 'radio' && !document.querySelector(`input[name="${input.name}"]:checked`))) {
                    valid = false;
                    input.style.borderColor = '#DC006D';
                } else {
                    input.style.borderColor = '#e5e5e5';
                }
            });

            if (!valid) {
                showMessage('Please fill in all required fields', 'error');
                return;
            }

            if (currentStep === 3) {
                // Generate review content before showing step 4
                generateReviewContent();
            }

            if (currentStep < totalSteps) {
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.remove('active');
                currentStep++;
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.add('active');
                updateProgressBar();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.remove('active');
                currentStep--;
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.add('active');
                updateProgressBar();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        function generateReviewContent() {
            const form = document.getElementById('landlordForm');
            const formData = new FormData(form);
            const registrationType = formData.get('registration_type');

            let html = '<h3 style="color: #25073B; margin-bottom: 15px;">Personal Details</h3>';
            html += `<p><strong>Registration Type:</strong> ${registrationType}</p>`;
            html += `<p><strong>Name:</strong> ${formData.get('firstName')} ${formData.get('surname')}</p>`;
            html += `<p><strong>Email:</strong> ${formData.get('email')}</p>`;
            html += `<p><strong>Phone:</strong> ${formData.get('phone')}</p>`;
            html += `<p><strong>Address:</strong> ${formData.get('address')}, ${formData.get('postcode')}</p>`;

            if (registrationType === 'Joint') {
                html += '<h3 style="color: #25073B; margin-top: 20px; margin-bottom: 15px;">Joint Applicant</h3>';
                html += `<p><strong>Name:</strong> ${formData.get('firstName2')} ${formData.get('surname2')}</p>`;
                html += `<p><strong>Email:</strong> ${formData.get('email2')}</p>`;
                html += `<p><strong>Phone:</strong> ${formData.get('phone2')}</p>`;
            }

            html += '<h3 style="color: #25073B; margin-top: 20px; margin-bottom: 15px;">Property Details</h3>';
            html += `<p><strong>Address:</strong> ${formData.get('propertyAddress')}, ${formData.get('propertyPostcode')}</p>`;
            html += `<p><strong>Bedrooms:</strong> ${formData.get('bedrooms')}</p>`;
            html += `<p><strong>Already Let:</strong> ${formData.get('alreadyLet')}</p>`;
            html += `<p><strong>Ownership:</strong> ${formData.get('ownershipStructure')}</p>`;

            document.getElementById('reviewContent').innerHTML = html;
        }

        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            container.innerHTML = `<div class="message ${type} show">${message}</div>`;
            setTimeout(() => {
                container.innerHTML = '';
            }, 5000);
        }

        // Form submission
        document.getElementById('landlordForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const termsConsent = document.getElementById('termsConsent');
            if (!termsConsent.checked) {
                showMessage('Please accept the Terms & Conditions to continue', 'error');
                return;
            }

            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Submitting... <span class="spinner"></span>';

            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());

            // Determine API URL - change this to your backend URL
            const API_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
                ? 'http://localhost:3001'
                : 'https://fleming-crm-api-production-7e58.up.railway.app';

            try {
                const response = await fetch(`${API_URL}/api/public/landlord-enquiries`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (response.ok) {
                    showMessage('Thank you! Your application has been submitted successfully. We will contact you shortly.', 'success');

                    // Reset form and return to step 1 after 3 seconds
                    setTimeout(() => {
                        this.reset();
                        currentStep = 1;
                        document.querySelectorAll('.step').forEach(step => step.classList.remove('active'));
                        document.querySelector('.step[data-step="1"]').classList.add('active');
                        updateProgressBar();
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }, 3000);
                } else {
                    showMessage(result.error || 'An error occurred. Please try again.', 'error');
                }
            } catch (error) {
                console.error('Submission error:', error);
                showMessage('An error occurred. Please try again or contact us directly.', 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Submit Application';
            }
        });

        // Initialize
        updateProgressBar();
    </script>
</body>
</html>
