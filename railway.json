{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "chmod +x render-build.sh && ./render-build.sh"
    },
    "deploy": {
        "startCommand": "cd backend && node dist/index.js",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}
